import random
import string

# 小锌懈褋芯泻 褋懈屑胁芯谢芯胁, 泻芯褌芯褉褘械 屑褘 褍屑械械屑 褕懈褎褉芯胁邪褌褜
CHARS = string.ascii_letters + string.digits + string.punctuation + " " + "邪斜胁谐写械褢卸蟹懈泄泻谢屑薪芯锌褉褋褌褍褎褏褑褔褕褖褗褘褜褝褞褟袗袘袙袚袛袝衼袞袟袠袡袣袥袦袧袨袩袪小孝校肖啸笑效楔些歇蝎鞋协挟携"

def process_text(text, key, mode):
    result = ""
    for i in range(len(text)):
        char = text[i]
        if char in CHARS:
            idx = CHARS.find(char)
            # 袘械褉械屑 褋懈屑胁芯谢 懈蟹 泻谢褞褔邪 锌芯 泻褉褍谐褍 (褑懈泻谢懈褔械褋泻懈泄 褋写胁懈谐)
            key_char = key[i % len(key)]
            key_idx = CHARS.find(key_char)
            
            if mode == 'enc':
                new_idx = (idx + key_idx) % len(CHARS)
            else:
                new_idx = (idx - key_idx) % len(CHARS)
            result += CHARS[new_idx]
        else:
            result += char # 袝褋谢懈 褋懈屑胁芯谢邪 薪械褌 胁 褋锌懈褋泻械, 芯褋褌邪胁谢褟械屑 泻邪泻 械褋褌褜
    return result

# --- 袨小袧袨袙袧袨袡 袠袧孝袝袪肖袝袡小 ---
print("--- 袩褉芯褋褌芯泄 楔懈褎褉邪褌芯褉/袛械褕懈褎褉邪褌芯褉 ---")
action = input("袙褘斜械褉懈 写械泄褋褌胁懈械 (1 - 楔懈褎褉芯胁邪褌褜, 2 - 袪邪褋褕懈褎褉芯胁邪褌褜): ")

if action == '1':
    msg = input("袙胁械写懈褌械 褌械泻褋褌 写谢褟 褕懈褎褉芯胁泻懈: ")
    # 袚械薪械褉懈褉褍械屑 褋谢褍褔邪泄薪褘泄 泻谢褞褔 褌邪泻芯泄 卸械 写谢懈薪褘, 泻邪泻 褋芯芯斜褖械薪懈械
    generated_key = ''.join(random.choice(CHARS) for _ in range(len(msg)))
    
    cipher = process_text(msg, generated_key, 'enc')
    
    print("\n--- 袪袝袟校袥鞋孝袗孝 楔袠肖袪袨袙袗袧袠携 ---")
    print(f"袟邪褕懈褎褉芯胁邪薪薪褘泄 褌械泻褋褌: {cipher}")
    print(f"袣袥挟效 (褋泻芯锌懈褉褍泄褌械 械谐芯!): {generated_key}")

elif action == '2':
    cipher_input = input("袙胁械写懈褌械 蟹邪褕懈褎褉芯胁邪薪薪褘泄 褌械泻褋褌: ")
    key_input = input("袙胁械写懈褌械 泻谢褞褔: ")
    
    if not key_input:
        print("袨褕懈斜泻邪: 泻谢褞褔 薪械 屑芯卸械褌 斜褘褌褜 锌褍褋褌褘屑!")
    else:
        result = process_text(cipher_input, key_input, 'dec')
        print("\n--- 袪袝袟校袥鞋孝袗孝 袪袗小楔袠肖袪袨袙袣袠 ---")
        print(f"袨褉懈谐懈薪邪谢褜薪褘泄 褌械泻褋褌: {result}")

